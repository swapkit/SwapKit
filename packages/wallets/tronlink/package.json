{
  "description": "SwapKit Wallet - Tronlink",
  "dependencies": {
    "@swapkit/helpers": "workspace:*",
    "@swapkit/toolbox-tron": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "typescript": "5.7.2"
  },
  "files": [
    "src/",
    "dist/"
  ],
  "homepage": "https://github.com/thorswap/SwapKit",
