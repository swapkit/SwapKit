{
  "name": "@swapkit/ui",
  "version": "0.1.0-beta.19",
  "private": true,
  "dependencies": {
    "@swapkit/core": "workspace:*",
    "@swapkit/plugins": "workspace:*",
    "@swapkit/toolboxes": "workspace:*",
    "@swapkit/wallets": "workspace:*",
    "fuzzysort": "3.1.0",
    "react-window": "1.8.11",
    "react-window-infinite-loader": "1.0.10",
    "ts-pattern": "5.7.1",
    "zustand": "5.0.5"
  },
  "devDependencies": {
    "@types/react-window": "1.8.8",
    "bun-plugin-tailwind": "0.0.15",
    "fuse.js": "^7.1.0",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "author": "swapkit-oss",
  "description": "SwapKit - UI",
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "types": "./src/index.ts"
    },
    "./react": {
      "default": "./dist/react/index.js",
      "require": "./dist/react/index.cjs",
      "types": "./src/react/index.tsx"
    },
    "./styles": {
      "default": "./dist/index.css",
      "types": "./src/index.css"
    },
    "./core": {
      "default": "./dist/core/index.js",
      "types": "./src/core/index.ts"
    }
  },
  "files": ["src/", "dist/"],
  "homepage": "https://github.com/thorswap/SwapKit",
  "license": "Apache-2.0",
  "repository": {
    "directory": "packages/ui",
    "type": "git",
    "url": "git+https://github.com/thorswap/SwapKit.git"
  },
  "scripts": {
    "build": "bun run ./build.ts",
    "build:clean": "rm -rf dist && bun run ./build.ts",
    "clean": "rm -rf dist node_modules *.tsbuildinfo",
    "preview": "bunx vite preview.html",
    "test": "bun test",
    "test:ci": "bun test --coverage",
    "type-check": "tsc --noEmit"
  },
  "type": "module"
}
