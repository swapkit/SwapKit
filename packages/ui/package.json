{
  "name": "@swapkit/ui",
  "version": "0.0.2-beta.0",
  "private": true,
  "dependencies": {
    "@swapkit/core": "workspace:*",
    "@swapkit/plugins": "workspace:*",
    "@swapkit/toolboxes": "workspace:*",
    "@swapkit/wallets": "workspace:*",
    "ts-pattern": "5.6.2"
  },
  "devDependencies": {
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "author": "swapkit-oss",
  "description": "SwapKit - UI",
  "exports": {
    "./react": {
      "default": "./dist/react/index.js",
      "require": "./dist/react/index.cjs",
      "types": "./src/react/index.tsx"
    }
  },
  "files": ["src/", "dist/"],
  "homepage": "https://github.com/thorswap/SwapKit",
  "license": "Apache-2.0",
  "repository": {
    "directory": "packages/ui",
    "type": "git",
    "url": "git+https://github.com/thorswap/SwapKit.git"
  },
  "scripts": {
    "build": "bun run ./build.ts",
    "clean": "rm -rf dist node_modules *.tsbuildinfo",
    "lint": "biome check --write ./src",
    "test": "bun test",
    "test:ci": "bun test --coverage"
  },
  "type": "module"
}
