{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "files": {
    "ignore": ["node_modules", "dist", "coverage", "MsgCompiled.ts", ".astro"],
    "maxSize": 5242880
  },
  "formatter": {
    "formatWithErrors": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "semicolons": "always"
    },
    "globals": ["Bun", "React"]
  },
  "json": {
    "formatter": {
      "indentStyle": "space"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "a11y": {
        "noSvgWithoutTitle": "off",
        "recommended": true,
        "useSemanticElements": "off"
      },
      "complexity": {
        "all": true,
        "noBannedTypes": "off"
      },
      "correctness": {
        "all": true,
        "noNodejsModules": "off",
        "noUndeclaredDependencies": "off",
        "noUndeclaredVariables": "error",
        "useImportExtensions": "off"
      },
      "nursery": {
        "noDescendingSpecificity": "off",
        "recommended": true
      },
      "recommended": true,
      "security": {
        "all": true
      },
      "style": {
        "all": true,
        "noDefaultExport": "off",
        "noImplicitBoolean": "off",
        "noNamespaceImport": "off",
        "useBlockStatements": "off",
        "useExplicitLengthCheck": "off",
        "useFilenamingConvention": "off",
        "useNamingConvention": "off",
        "useNodejsImportProtocol": "off"
      },
      "suspicious": {
        "all": true,
        "noArrayIndexKey": "off",
        "noConsole": {
          "level": "warn",
          "options": {
            "allow": ["info", "warn", "error"]
          }
        },
        "noEvolvingTypes": "off",
        "noExplicitAny": "off",
        "noReactSpecificProps": "off",
        "useAwait": "error"
      }
    }
  },
  "organizeImports": {
    "enabled": true
  }
}
