# SwapKit Environment Variables
# Copy this file to .env and fill in your values

# SwapKit API Key (required for quotes)
VITE_SWAPKIT_API_KEY=your_api_key_here

# Development mode
VITE_NODE_ENV=development

# Other potential environment variables
VITE_SWAPKIT_API_URL=https://api.swapkit.dev
VITE_SWAPKIT_DEV_API_URL=https://dev-api.swapkit.dev